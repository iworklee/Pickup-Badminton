<view class="index-page">
  <view class="header">
    <text class="title">路人羽球</text>
    <text class="desc">创建或进入活动，实时看板与排行榜</text>
  </view>
  <view class="actions">
    <button class="btn-primary" bindtap="goCreate">创建活动</button>
    <view class="divider">或进入已有活动</view>
    <input class="input" placeholder="输入活动 ID" value="{{activityId}}" bindinput="onActivityIdInput" />
    <button class="btn-secondary" bindtap="goLive">进入看板</button>
  </view>
  <view class="recent-section" wx:if="{{recentList.length > 0}}">
    <view class="recent-title">最近的活动</view>
    <view class="recent-list">
      <view class="recent-item" wx:for="{{recentList}}" wx:key="id" data-id="{{item.id}}" bindtap="goLiveById">
        <text class="recent-name">{{item.title}}</text>
        <text class="recent-id">{{item.id}}</text>
      </view>
    </view>
  </view>
</view>
