.index-page {
  min-height: 100vh;
  background: #f7f8fa;
  padding: 80rpx 48rpx;
}
.header {
  text-align: center;
  margin-bottom: 80rpx;
}
.title {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: #323233;
  margin-bottom: 16rpx;
}
.desc {
  font-size: 28rpx;
  color: #969799;
}
.actions {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.btn-primary {
  background: #1989fa;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  margin-bottom: 32rpx;
}
.divider {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #969799;
  margin-bottom: 24rpx;
}
.input {
  width: 100%;
  padding: 24rpx;
  font-size: 28rpx;
  background: #f7f8fa;
  border-radius: 16rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}
.btn-secondary {
  background: #fff;
  color: #1989fa;
  border: 1rpx solid #1989fa;
  border-radius: 48rpx;
  font-size: 28rpx;
}
