.index-page {
  min-height: 100vh;
  background: #f7f8fa;
  padding: 80rpx 48rpx;
}
.header {
  text-align: center;
  margin-bottom: 80rpx;
}
.title {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: #323233;
  margin-bottom: 16rpx;
}
.desc {
  font-size: 28rpx;
  color: #969799;
}
.actions {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.btn-primary {
  background: #1989fa;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  margin-bottom: 32rpx;
}
.divider {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #969799;
  margin-bottom: 24rpx;
}
.input {
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  line-height: 88rpx;
  background: #f7f8fa;
  border-radius: 16rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}
.btn-secondary {
  background: #fff;
  color: #1989fa;
  border: 1rpx solid #1989fa;
  border-radius: 48rpx;
  font-size: 28rpx;
}

.recent-section {
  margin-top: 48rpx;
  padding: 0 8rpx;
}

.recent-title {
  font-size: 28rpx;
  color: #969799;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.recent-list {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.recent-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-name {
  font-size: 30rpx;
  color: #323233;
}

.recent-id {
  font-size: 22rpx;
  color: #c8c9cc;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
